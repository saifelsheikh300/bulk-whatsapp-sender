<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:orientation="vertical"
    android:layoutDirection="rtl">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/bg_card"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">
        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_whatsapp_logo"
            android:layout_marginEnd="10dp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="واتساب الطيار"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="@font/cairo" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Accessibility Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                style="@style/CardStyle">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="خدمة الإمكانية"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/cairo" />
                        <TextView
                            android:id="@+id/tvAccessibilityStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="غير مفعلة"
                            android:textColor="@color/red_error"
                            android:textSize="12sp"
                            android:fontFamily="@font/cairo" />
                    </LinearLayout>
                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnEnableAccessibility"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="تفعيل"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:textAllCaps="false"
                        android:background="@drawable/btn_green"
                        android:fontFamily="@font/cairo"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- WhatsApp Selector -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                style="@style/CardStyle">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="تطبيق الإرسال"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:fontFamily="@font/cairo"
                        android:layout_marginBottom="10dp" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <LinearLayout
                            android:id="@+id/btnWhatsAppNormal"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/selector_whatsapp_btn"
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:clickable="true"
                            android:focusable="true">
                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_whatsapp_logo"
                                android:layout_marginEnd="6dp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="واتساب عادي"
                                android:textColor="@color/text_primary"
                                android:textSize="13sp"
                                android:fontFamily="@font/cairo" />
                        </LinearLayout>
                        <LinearLayout
                            android:id="@+id/btnWhatsAppBusiness"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:background="@drawable/selector_whatsapp_btn"
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:clickable="true"
                            android:focusable="true">
                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_whatsapp_business"
                                android:layout_marginEnd="6dp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="واتساب بيزنس"
                                android:textColor="@color/text_primary"
                                android:textSize="13sp"
                                android:fontFamily="@font/cairo" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Contacts Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardContacts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                style="@style/CardStyle">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">
                    <LinearLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/circle_green"
                        android:gravity="center"
                        android:layout_marginEnd="12dp">
                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_contacts" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="جهات الاتصال"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/cairo" />
                        <TextView
                            android:id="@+id/tvContactsCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="لم يتم التحديد بعد"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:fontFamily="@font/cairo" />
                    </LinearLayout>
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_arrow_left"
                        android:alpha="0.5" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ═══ الرسائل المتعددة ═══ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                style="@style/CardStyle">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <!-- عنوان القسم -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🎲 الرسائل (إرسال عشوائي)"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/cairo" />
                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btnAddVariant"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="+ إضافة رسالة"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:textAllCaps="false"
                            android:background="@drawable/btn_green"
                            android:fontFamily="@font/cairo"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp" />
                    </LinearLayout>

                    <!-- hint -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="كل جهة اتصال ستستلم رسالة مختارة عشوائياً"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:fontFamily="@font/cairo"
                        android:layout_marginBottom="12dp" />

                    <!-- عدد الرسائل -->
                    <TextView
                        android:id="@+id/tvVariantsCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/green_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/cairo"
                        android:layout_marginBottom="10dp"
                        android:visibility="gone" />

                    <!-- container الرسائل (يتملأ ديناميكياً) -->
                    <LinearLayout
                        android:id="@+id/containerVariants"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Delay Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                style="@style/CardStyle">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="⏱ التأخير بين كل رسالة"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/cairo" />
                        <TextView
                            android:id="@+id/tvDelayValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="10 ثانية"
                            android:textColor="@color/green_primary"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/cairo" />
                    </LinearLayout>
                    <SeekBar
                        android:id="@+id/seekBarDelay"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="25"
                        android:progress="5"
                        android:progressTint="@color/green_primary"
                        android:thumbTint="@color/green_primary" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="5 ث"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:fontFamily="@font/cairo" />
                        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="30 ث"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:fontFamily="@font/cairo" />
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚠ أقل من 7 ثواني قد يسبب حظر الحساب"
                        android:textColor="@color/orange_warning"
                        android:textSize="12sp"
                        android:fontFamily="@font/cairo"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Start Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnStart"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="🚀 ابدأ الإرسال"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:textAllCaps="false"
                android:background="@drawable/btn_green"
                android:fontFamily="@font/cairo"
                android:layout_marginBottom="30dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
